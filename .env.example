# Copy this file to .env and fill values locally. Do not commit .env.
# Windows PowerShell:
#   copy .env.example .env
#   notepad .env
# Linux/macOS:
#   cp .env.example .env

# Preferred key for DeepSeek API mode.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional generic OpenAI-compatible override. If set, OPENAGENT_* takes priority.
OPENAGENT_API_KEY=
OPENAGENT_BASE_URL=

# Optional fallback for OpenAI-compatible endpoints.
OPENAI_API_KEY=
